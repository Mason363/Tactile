{
  "manifest_version": 3,
  "name": "Tactile Browser Bridge",
  "version": "0.1.0",
  "description": "Feeds Tactile the real DOM under your cursor, so web controls that never reach macOS accessibility can still be felt.",
  "minimum_chrome_version": "102",
  "key": "",
  "permissions": ["nativeMessaging"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
