<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sparkle update settings. The rest of Info.plist is still generated by
	     GENERATE_INFOPLIST_FILE; this file only adds the custom keys Xcode's
	     INFOPLIST_KEY_ build settings can't inject. -->
	<key>SUFeedURL</key>
	<string>https://raw.githubusercontent.com/Mason363/Tactile/main/appcast.xml</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<!-- SUPublicEDKey: paste the public key from Sparkle's generate_keys before
	     publishing a signed update (see README → Releasing). Absent for now so
	     unsigned dev builds still run; update installation stays disabled until
	     it's set. -->
</dict>
</plist>
